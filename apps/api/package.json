{
  "name": "@coopsource/api",
  "version": "0.1.0",
  "private": true,
  "description": "Co-op Source Network API server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:federation": "vitest run --config vitest.federation.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/mcp": "^1.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@atproto/api": "^0.19.0",
    "@atproto/crypto": "^0.4.5",
    "@atproto/oauth-client-node": "^0.3.17",
    "@atproto/tap": "^0.2.11",
    "@coopsource/common": "workspace:*",
    "@coopsource/db": "workspace:*",
    "@coopsource/federation": "workspace:*",
    "@coopsource/lexicons": "workspace:*",
    "@ipld/dag-cbor": "^9.2.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^6.0.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "esbuild": "^0.27.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "kysely": "^0.28.14",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "stripe": "^20.4.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"

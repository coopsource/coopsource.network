  "devDependencies": {
    "@coopsource/config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "pg": "^8.19.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"

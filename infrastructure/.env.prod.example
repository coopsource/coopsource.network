# Co-op Source Network — Production Environment
# Copy to .env in the infrastructure/ directory before running docker-compose.prod.yml

# --- Domain ---
DOMAIN=coopsource.network

# --- PostgreSQL ---
POSTGRES_DB=coopsource
POSTGRES_USER=coopsource
POSTGRES_PASSWORD=          # REQUIRED: generate with `openssl rand -hex 32`

# --- Redis ---
REDIS_PASSWORD=             # REQUIRED: generate with `openssl rand -hex 32`

# --- Secrets ---
SESSION_SECRET=             # REQUIRED: min 32 chars, generate with `openssl rand -hex 32`
KEY_ENC_KEY=                # REQUIRED: generate with `openssl rand -base64 32`

# --- ATProto Federation (optional, for V6 features) ---
# PLC_URL=https://plc.directory
# COOP_PDS_URL=https://pds.coopsource.network
# COOP_DID=did:plc:<from provisioning>
# RELAY_URL=wss://bsky.network

# --- Email (SMTP, optional) ---
# Leave SMTP_HOST unset to disable email. Invitations still work via shareable links.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com

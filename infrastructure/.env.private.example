# Co-op Source Network — Private Network Environment
# For a fully self-hosted network disconnected from public ATProto.
# Copy to .env.private in the infrastructure/ directory.

# --- Domain ---
DOMAIN=coopsource.local

# --- PDS (MUST be a different domain from DOMAIN) ---
PDS_HOSTNAME=pds.coopsource-pds.local
PDS_JWT_SECRET=              # REQUIRED: generate with `openssl rand -hex 32`
PDS_ADMIN_PASSWORD=          # REQUIRED: generate with `openssl rand -hex 16`
# PDS_ROTATION_KEY=          # Optional: secp256k1 hex key for PLC rotation

# --- Relay ---
RELAY_ADMIN_PASSWORD=        # REQUIRED: generate with `openssl rand -hex 16`

# --- Tap ---
# TAP_ADMIN_PASSWORD=        # Optional: Tap admin API password (defaults to empty)

# --- PostgreSQL ---
POSTGRES_DB=coopsource
POSTGRES_USER=coopsource
POSTGRES_PASSWORD=           # REQUIRED: generate with `openssl rand -hex 32`

# --- Redis ---
REDIS_PASSWORD=              # REQUIRED: generate with `openssl rand -hex 32`

# --- Secrets ---
SESSION_SECRET=              # REQUIRED: min 32 chars, generate with `openssl rand -hex 32`
KEY_ENC_KEY=                 # REQUIRED: generate with `openssl rand -base64 32`

# --- Email (optional) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@coopsource.local

# ATProto PDS + PLC Configuration
# Copy to .env in the infrastructure/ directory and customize.

# --- PDS ---

# Hostname the PDS is reachable at (used for handle resolution)
# Local dev: localhost
# Production: pds.yourdomain.com
PDS_HOSTNAME=localhost

# Admin password for the PDS (used by provisioning script)
PDS_ADMIN_PASSWORD=admin

# JWT secret for PDS session tokens (min 32 chars, generate with: openssl rand -hex 32)
PDS_JWT_SECRET=dev-jwt-secret-change-me-32chars!!

# PDS rotation key (secp256k1 private key, hex-encoded)
# Generate with: openssl ecparam -genkey -name secp256k1 -noout | openssl ec -text -noout 2>/dev/null | grep -A3 'priv:' | tail -3 | tr -d ' :\n'
# Or leave empty — PDS will generate one on first start.
PDS_ROTATION_KEY=

# --- Application (set after running `make provision-coop`) ---

# COOP_PDS_URL=http://localhost:2583
# COOP_PDS_ADMIN_PASSWORD=admin
# COOP_DID=did:plc:<from-provisioning>
# COOP_ROTATION_KEY_HEX=<from-provisioning>

# PLC directory URL
# Local dev: http://localhost:2582
# Production: https://plc.directory
# PLC_URL=http://localhost:2582

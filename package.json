{
  "name": "coopsource-network",
  "version": "0.1.0",
  "private": true,
  "description": "Co-op Source Network — federated collaboration platform on ATProtocol",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,svelte,js,mjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,svelte,js,mjs,json,css,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "dev:setup": "./scripts/dev-services.sh setup",
    "dev:infra": "./scripts/dev-services.sh start",
    "dev:stop": "./scripts/dev-services.sh stop",
    "dev:status": "./scripts/dev-services.sh status",
    "db:migrate": "./scripts/dev-services.sh db:migrate",
    "db:reset": "./scripts/dev-services.sh db:reset",
    "test:e2e": "pnpm --filter @coopsource/web exec playwright test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "esbuild"],
    "overrides": {
      "kysely": "^0.28.14",
      "hono": ">=4.12.7",
      "express-rate-limit": ">=8.2.2",
      "@hono/node-server": ">=1.19.10",
      "undici": ">=6.24.0",
      "cookie": ">=0.7.0",
      "devalue": ">=5.6.4",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=2.0.3",
      "rollup": ">=4.59.0"
    }
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.11",
    "typescript": "^5.9.3"
  }
}
